# LAWIM_V2 developer platform — local overrides (optional)
# Copy to .env.platform at repository root and adjust.

# PostgreSQL dev container (Podman/Docker)
LAWIM_POSTGRES_PORT=5433
LAWIM_POSTGRES_USER=lawim
LAWIM_POSTGRES_PASSWORD=lawim
LAWIM_POSTGRES_DB=lawim_v2

# Tests and smoke
LAWIM_TEST_POSTGRES_URL=postgresql://lawim:lawim@127.0.0.1:5433/lawim_v2

# Compose command override (auto-detected if unset)
# LAWIM_COMPOSE=podman-compose

# Python virtualenv for platform tooling
LAWIM_PLATFORM_VENV=.venv-platform
