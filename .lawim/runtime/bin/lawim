#!/usr/bin/env sh
set -eu

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
RUNTIME_ROOT=$(CDPATH= cd -- "$SCRIPT_DIR/.." && pwd)
PROJECT_ROOT=$(CDPATH= cd -- "$SCRIPT_DIR/../../.." && pwd)

usage() {
  cat <<EOF
LAWIM runtime minimal executable

Usage:
  lawim <command>

Minimal executable surface:
  lawim --help
  lawim status
  lawim doctor
  lawim git-sync --status
  lawim git-sync --commit "<message>"
  lawim git-sync --tag "<tag>"
  lawim git-sync --push

Prepared commands:
  status
  doctor
  run
  batch-run
  review
  close-sprint
  git-sync

Contract docs:
  $RUNTIME_ROOT/docs/COMMANDS.md
  $RUNTIME_ROOT/docs/SERVICES.md
  $RUNTIME_ROOT/docs/POLICIES.md
EOF
}

git_available() {
  command -v git >/dev/null 2>&1
}

git_in_repo() {
  git_available && git -C "$PROJECT_ROOT" rev-parse --is-inside-work-tree >/dev/null 2>&1
}

git_branch() {
  git -C "$PROJECT_ROOT" branch --show-current 2>/dev/null || true
}

git_clean_state() {
  if [ -n "$(git -C "$PROJECT_ROOT" status --short 2>/dev/null || true)" ]; then
    printf '%s\n' "sale"
  else
    printf '%s\n' "propre"
  fi
}

git_head_commit() {
  git -C "$PROJECT_ROOT" log -1 --oneline 2>/dev/null || true
}

git_last_tag() {
  git -C "$PROJECT_ROOT" tag --sort=-creatordate 2>/dev/null | sed -n '1p' || true
}

git_recent_tags() {
  git -C "$PROJECT_ROOT" tag --sort=-creatordate 2>/dev/null | sed -n '1,5p' || true
}

git_remote_state() {
  if [ -n "$(git -C "$PROJECT_ROOT" remote 2>/dev/null || true)" ]; then
    printf '%s\n' "present"
  else
    printf '%s\n' "absent"
  fi
}

git_has_remote() {
  [ "$(git_remote_state)" = "present" ]
}

is_blank() {
  case $1 in
    *[![:space:]]*) return 1 ;;
    *) return 0 ;;
  esac
}

git_sync_usage() {
  cat <<EOF
LAWIM git-sync

Usage:
  lawim git-sync --status
  lawim git-sync --commit "<message>"
  lawim git-sync --tag "<tag>"
  lawim git-sync --push

Rules:
  - --commit refuses empty messages and clean trees.
  - --tag refuses empty tags and existing tags.
  - --push refuses when no remote is configured.
  - No remote is ever configured by this command.
  - No force push and no tag deletion.
EOF
}

git_sync_fail() {
  printf '%s\n' "$1"
  exit "${2:-2}"
}

git_sync_status() {
  critical=0
  printf '%s\n' "LAWIM git-sync status"

  if git_in_repo; then
    branch=$(git_branch)
    [ -n "$branch" ] || branch="DETACHED"
    printf 'Etat Git: %s\n' "$(git_clean_state)"
    printf 'Branche Git: %s\n' "$branch"
    head_commit=$(git_head_commit)
    [ -n "$head_commit" ] || head_commit="indetectable"
    printf 'Dernier commit: %s\n' "$head_commit"
    last_tag=$(git_last_tag)
    [ -n "$last_tag" ] || last_tag="aucun"
    printf 'Dernier tag: %s\n' "$last_tag"
    printf 'Derniers tags:\n'
    recent_tags=$(git_recent_tags)
    if [ -n "$recent_tags" ]; then
      printf '%s\n' "$recent_tags" | sed 's/^/- /'
    else
      printf '%s\n' "- aucun"
    fi
    printf 'Remote Git: %s\n' "$(git_remote_state)"
  else
    printf '%s\n' "Etat Git: indetectable"
    printf '%s\n' "Branche Git: indetectable"
    printf '%s\n' "Dernier commit: indetectable"
    printf '%s\n' "Dernier tag: indetectable"
    printf '%s\n' "Derniers tags: indetectable"
    printf '%s\n' "Remote Git: indetectable"
    critical=1
  fi

  exit "$critical"
}

git_sync_commit() {
  message=$1

  if is_blank "$message"; then
    git_sync_fail "Refus: message de commit vide." 2
  fi

  if ! git_in_repo; then
    git_sync_fail "Refus: depot Git introuvable." 2
  fi

  if [ "$(git_clean_state)" = "propre" ]; then
    git_sync_fail "Refus: aucun changement a committer." 2
  fi

  git -C "$PROJECT_ROOT" add -A
  git -C "$PROJECT_ROOT" commit -m "$message"
}

git_sync_tag() {
  tag=$1

  if is_blank "$tag"; then
    git_sync_fail "Refus: nom de tag vide." 2
  fi

  if ! git_in_repo; then
    git_sync_fail "Refus: depot Git introuvable." 2
  fi

  if ! git -C "$PROJECT_ROOT" rev-parse --verify HEAD >/dev/null 2>&1; then
    git_sync_fail "Refus: aucun commit HEAD disponible." 2
  fi

  if git -C "$PROJECT_ROOT" show-ref --tags --verify --quiet "refs/tags/$tag"; then
    git_sync_fail "Refus: le tag existe deja." 2
  fi

  git -C "$PROJECT_ROOT" tag "$tag"
  printf 'Tag cree: %s\n' "$tag"
}

git_sync_push() {
  if ! git_in_repo; then
    git_sync_fail "Refus: depot Git introuvable." 2
  fi

  if ! git_has_remote; then
    git_sync_fail "Refus: aucun remote Git configure." 2
  fi

  branch=$(git_branch)
  if [ -z "$branch" ] || [ "$branch" = "HEAD" ]; then
    git_sync_fail "Refus: branche courante indeterminee." 2
  fi

  git -C "$PROJECT_ROOT" push
}

read_pcc_field() {
  field=$1
  pcc_file="$PROJECT_ROOT/.lawim/pcc/PCC.md"
  if [ ! -f "$pcc_file" ]; then
    return 1
  fi
  awk -F': ' -v needle="$field" '$0 ~ "^- " needle ":" {print $2; exit}' "$pcc_file"
}

print_status() {
  critical=0
  printf '%s\n' "LAWIM status"

  if git_in_repo; then
    branch=$(git_branch)
    [ -n "$branch" ] || branch="DETACHED"
    printf 'Branche Git: %s\n' "$branch"
    printf 'Depot: %s\n' "$(git_clean_state)"
    head_commit=$(git_head_commit)
    [ -n "$head_commit" ] || head_commit="indetectable"
    printf 'Dernier commit: %s\n' "$head_commit"
    last_tag=$(git_last_tag)
    [ -n "$last_tag" ] || last_tag="aucun"
    printf 'Dernier tag: %s\n' "$last_tag"
    sprint_active=$(read_pcc_field "Sprint actif" 2>/dev/null || true)
    [ -n "$sprint_active" ] || sprint_active="indetectable"
    printf 'Sprint actif: %s\n' "$sprint_active"
    program_status=$(read_pcc_field "Programme status" 2>/dev/null || true)
    [ -n "$program_status" ] || program_status="indetectable"
    printf 'Etat programme: %s\n' "$program_status"
    printf 'Remote Git: %s\n' "$(git_remote_state)"
  else
    printf '%s\n' "Branche Git: indetectable"
    printf '%s\n' "Depot: indetectable"
    printf '%s\n' "Dernier commit: indetectable"
    printf '%s\n' "Dernier tag: indetectable"
    printf '%s\n' "Sprint actif: indetectable"
    printf '%s\n' "Etat programme: indetectable"
    printf '%s\n' "Remote Git: indetectable"
    critical=1
  fi

  exit "$critical"
}

print_doctor() {
  critical=0
  printf '%s\n' "LAWIM doctor"

  check_path() {
    label=$1
    path=$2
    if [ -e "$PROJECT_ROOT/$path" ]; then
      printf '[OK] %s: present\n' "$label"
    else
      printf '[FAIL] %s: missing\n' "$label"
      critical=1
    fi
  }

  check_path ".lawim" ".lawim"
  check_path "PCC" ".lawim/pcc/PCC.md"
  check_path "Sprints" ".lawim/sprints"
  check_path "Tickets" ".lawim/tickets"
  check_path "Reports" "reports"

  if git_available; then
    printf '%s\n' "[OK] Git: present"
  else
    printf '%s\n' "[FAIL] Git: missing"
    critical=1
  fi

  if git_in_repo; then
    printf '%s\n' "[OK] Git repo: present"
  else
    printf '%s\n' "[FAIL] Git repo: missing"
    critical=1
  fi

  if git_in_repo; then
    printf 'Etat depot: %s\n' "$(git_clean_state)"
    printf 'Remote Git: %s\n' "$(git_remote_state)"
    printf 'Tags recents:\n'
    recent_tags=$(git_recent_tags)
    if [ -n "$recent_tags" ]; then
      printf '%s\n' "$recent_tags" | sed 's/^/- /'
    else
      printf '%s\n' "- aucun"
    fi
  else
    printf '%s\n' "Etat depot: indetectable"
    printf '%s\n' "Remote Git: indetectable"
    printf '%s\n' "Tags recents: indetectable"
  fi

  exit "$critical"
}

stub_command() {
  command=$1
  printf '%s\n' "LAWIM runtime foundation stub: '$command' is defined but not implemented yet."
  printf '%s\n' "See $RUNTIME_ROOT/src/commands/$command.md and $RUNTIME_ROOT/docs/COMMANDS.md."
  exit 2
}

case "${1:-}" in
  status)
    print_status
    ;;
  doctor)
    print_doctor
    ;;
  git-sync)
    case "${2:-}" in
      --status)
        if [ "$#" -ne 2 ]; then
          git_sync_usage
          exit 2
        fi
        git_sync_status
        ;;
      --commit)
        if [ "$#" -ne 3 ]; then
          git_sync_usage
          exit 2
        fi
        git_sync_commit "${3:-}"
        ;;
      --tag)
        if [ "$#" -ne 3 ]; then
          git_sync_usage
          exit 2
        fi
        git_sync_tag "${3:-}"
        ;;
      --push)
        if [ "$#" -ne 2 ]; then
          git_sync_usage
          exit 2
        fi
        git_sync_push
        ;;
      ""|-h|--help|help)
        git_sync_usage
        ;;
      *)
        git_sync_usage
        exit 2
        ;;
    esac
    ;;
  run|batch-run|review|close-sprint)
    stub_command "$1"
    ;;
  ""|-h|--help|help)
    usage
    ;;
  *)
    printf '%s\n' "Unknown LAWIM runtime command: $1"
    usage
    exit 2
    ;;
esac
