  "data_quality_scoring": {
    "description": "Data quality scoring engine for property listings",
    "formula": "quality_score = int(completeness * 0.6 + reliability * 0.4)",
    "completeness": {
      "weight": 0.6,
      "dimensions": [
        {"field": "title", "weight": 0.10, "description": "Property title present"},
        {"field": "description", "weight": 0.15, "description": "Property description present and sufficient length"},
        {"field": "price", "weight": 0.15, "description": "Price information provided"},
        {"field": "location", "weight": 0.15, "description": "City and neighborhood provided"},
        {"field": "type", "weight": 0.15, "description": "Property type and family specified"},
        {"field": "images", "weight": 0.15, "description": "At least one image uploaded"},
        {"field": "contact", "weight": 0.15, "description": "Contact information provided"}
      ]
    },
    "reliability": {
      "weight": 0.4,
      "source_scores": {
        "agent": 90,
        "google_form": 85,
        "import": 70,
        "whatsapp": 50,
        "telegram": 50,
        "dashboard": 85,
        "api": 75,
        "unknown": 30
      }
    },
    "grading": {
      "description": "Letter grade assignment based on quality score",
      "thresholds": [
        {"grade": "A+", "min_score": 80, "description": "Excellent quality"},
        {"grade": "A", "min_score": 60, "description": "Good quality"},
        {"grade": "B", "min_score": 40, "description": "Average quality"},
        {"grade": "C", "min_score": 20, "description": "Below average quality"},
        {"grade": "D", "min_score": 0, "description": "Poor quality — needs improvement"}
      ]
    }
  },
