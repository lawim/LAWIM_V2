  "lifecycle": {
    "description": "10-step property lifecycle state machine",
    "states": [
      {"step": 1, "canonical_name": "creation", "gold_name": "Réception", "description": "Initial reception of property data into the system", "allowable_previous": [], "allowable_next": ["normalization"]},
      {"step": 2, "canonical_name": "normalization", "gold_name": "Normalisation", "description": "Data normalization and cleansing", "allowable_previous": ["creation"], "allowable_next": ["classification", "creation"]},
      {"step": 3, "canonical_name": "classification", "gold_name": "Classification", "description": "Family and type classification assignment", "allowable_previous": ["normalization"], "allowable_next": ["validation", "normalization"]},
      {"step": 4, "canonical_name": "validation", "gold_name": "Validation", "description": "Consistency and completeness checks", "allowable_previous": ["classification"], "allowable_next": ["published", "classification"]},
      {"step": 5, "canonical_name": "published", "gold_name": "Publication", "description": "Published and publicly visible", "allowable_previous": ["validation"], "allowable_next": ["matching", "archived", "validation"]},
      {"step": 6, "canonical_name": "matching", "gold_name": "Matching", "description": "Active in matching engine for demandeur scoring", "allowable_previous": ["published"], "allowable_next": ["mise_en_relation", "published", "archived"]},
      {"step": 7, "canonical_name": "mise_en_relation", "gold_name": "Mise en relation", "description": "Contact established between demandeur and détenteur", "allowable_previous": ["matching"], "allowable_next": ["suivi", "matching", "archived"]},
      {"step": 8, "canonical_name": "suivi", "gold_name": "Suivi", "description": "Transaction follow-up in progress", "allowable_previous": ["mise_en_relation"], "allowable_next": ["archived", "conserve", "mise_en_relation"]},
      {"step": 9, "canonical_name": "archived", "gold_name": "Archivage", "description": "Archived after completion or inactivity", "allowable_previous": ["published", "matching", "mise_en_relation", "suivi"], "allowable_next": ["conserve", "published"]},
      {"step": 10, "canonical_name": "conserve", "gold_name": "Conservation historique", "description": "Historical preservation — final terminal state", "allowable_previous": ["suivi", "archived"], "allowable_next": []}
    ]
