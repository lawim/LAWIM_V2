  "availability_states": {
    "description": "Availability state machine with guarded transitions",
    "states": [
      {
        "canonical_name": "available",
        "description": "Property is available for transaction",
        "allowable_transitions": ["pending", "archived"]
      },
      {
        "canonical_name": "pending",
        "description": "Property is reserved or under negotiation",
        "allowable_transitions": ["available", "rented", "sold", "archived"]
      },
      {
        "canonical_name": "rented",
        "description": "Property has been rented",
        "allowable_transitions": ["archived", "available"]
      },
      {
        "canonical_name": "sold",
        "description": "Property has been sold",
        "allowable_transitions": ["archived"]
      },
      {
        "canonical_name": "archived",
        "description": "No longer active on the market",
        "allowable_transitions": ["available"]
      }
    ],
    "transition_rules": [
      {"from": "available", "to": "pending", "guard": "reservation_or_negotiation_initiated"},
      {"from": "available", "to": "archived", "guard": "owner_request_or_90d_inactivity"},
      {"from": "pending", "to": "available", "guard": "reservation_cancelled"},
      {"from": "pending", "to": "rented", "guard": "rental_agreement_signed"},
      {"from": "pending", "to": "sold", "guard": "sale_completed"},
      {"from": "pending", "to": "archived", "guard": "deal_failed_or_withdrawn"},
      {"from": "rented", "to": "archived", "guard": "lease_ended"},
      {"from": "rented", "to": "available", "guard": "lease_terminated_early"},
      {"from": "sold", "to": "archived", "guard": "sale_finalized"},
      {"from": "archived", "to": "available", "guard": "relisted_by_owner"}
    ]
  },
