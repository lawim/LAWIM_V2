      "checks": ["ownership_verification", "agricultural_zoning_check"]
    },
    "hotel": {
      "required_documents": ["owner_id", "hotel_license", "property_title", "health_certificate"],
      "checks": ["ownership_verification", "hospitality_license_verification"]
    },
    "project": {
      "required_documents": ["developer_id", "building_permit", "land_title", "project_approval"],
      "checks": ["developer_verification", "permit_validation", "project_feasibility"]
    }
  },
