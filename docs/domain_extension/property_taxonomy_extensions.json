  "auto_archive": {
    "description": "Automatic archiving of stale properties after 90 days of inactivity",
    "rule": {
      "name": "90-day inactivity auto-archive",
      "trigger": "last_activity_at + 90 days without new activity",
      "action": "Move property lifecycle to 'archived' state",
      "notification": "Notify owner 7 days before auto-archive",
      "exclusions": ["properties in 'suivi' or 'conserve' state"],
      "gold_source": "PROPERTY_TYPE_CROSSWALK.md §7 (GAP-006)",
      "priority": "P2"
    },
    "check_frequency": "daily (cron)",
    "fields": {
      "last_activity_at": {"type": "DateTime", "description": "Timestamp of last property activity"},
      "expires_at": {"type": "DateTime", "description": "Auto-archive date (last_activity_at + 90 days)"}
    }
  },
  "extensible_taxonomy": {
    "description": "Extensible taxonomy node structure for property type classification",
    "node_structure": {
      "canonical_id": {"type": "String", "required": true, "description": "Unique hierarchical identifier (e.g., 'residential.apartment.studio_meuble')"},
      "canonical_name": {"type": "String", "required": true, "description": "Primary canonical name"},
      "aliases": {"type": "String[]", "required": false, "description": "Alternative names and legacy mappings"},
      "parent_id": {"type": "String", "required": false, "description": "Parent canonical ID for hierarchical relationships"},
      "family": {"type": "String", "required": true, "description": "Property family this type belongs to"},
      "applicable_transactions": {"type": "String[]", "required": true, "description": "Transaction types applicable to this property type"},
      "applicable_fields": {"type": "String[]", "required": false, "description": "Specific fields relevant for this type"},
      "qualification_matrix_ids": {"type": "String[]", "required": false, "description": "References to qualification matrices applicable to this type"},
      "matching_dimensions": {"type": "String[]", "required": false, "description": "Matching scoring dimensions relevant for this type"},
      "verification_requirements": {"type": "String[]", "required": false, "description": "Required verification documents or checks"},
      "status": {"type": "Enum", "required": true, "values": ["active", "deprecated", "draft"], "description": "Taxonomy node lifecycle status"},
      "version": {"type": "Integer", "required": true, "description": "Version number for change tracking"}
    },
    "design_rationale": {
      "why_not_monolithic_enums": [
        "Monolithic enums become unmanageable with 76+ types across 7 families — a single enum would have too many values causing maintenance complexity",
        "Family-specific validation rules require polymorphic handling that a flat enum cannot express",
        "Per-family sub-referentials evolve independently — a monolithic enum creates coupling between unrelated types",
        "Qualification matrix binding is per-type not per-enum — a flat enum cannot carry metadata",
        "Legacy compatibility requires aliasing and mapping — a structured taxonomy supports this naturally",
        "Extensibility: new types can be added per family without affecting other families or the overall enum contract",
        "Versioning: individual types can be deprecated or versioned without breaking the entire classification system"
      ],
      "approach": "Hierarchical taxonomy with family-scoped type registries, referenced via canonical_id strings"
    }
  },
  "verification_requirements": {
    "description": "Verification requirements per property type category",
    "land": {
      "required_documents": ["title_deed_or_proof", "owner_id", "tax_receipt"],
      "checks": ["title_status_verification", "cadastral_reference_match", "ownership_chain"]
    },
    "residential": {
      "required_documents": ["owner_id", "property_title", "tax_receipt"],
      "checks": ["ownership_verification", "property_visit_confirmation"]
    },
    "commercial": {
      "required_documents": ["owner_id", "commercial_license", "property_title", "tax_receipt"],
      "checks": ["ownership_verification", "commercial_zoning_check"]
    },
    "industrial": {
      "required_documents": ["owner_id", "industrial_permit", "property_title", "environmental_clearance"],
      "checks": ["ownership_verification", "industrial_zoning_check", "environmental_compliance"]
    },
    "agricultural": {
