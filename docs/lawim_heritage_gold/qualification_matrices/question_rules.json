  "priority_order": [
    "intent",
    "transaction_type",
    "property_type",
    "city",
    "neighborhood",
    "budget",
    "deadline",
    "specific_criteria",
    "preferences",
    "confirmation"
  ],
  "rules": [
    {
      "id": "RULE-001",
      "description": "Never re-ask a confirmed fact. Once a field has been collected and confirmed, it must never be asked again in the same qualification session."
    },
    {
      "id": "RULE-002",
      "description": "Extract multiple fields from same message. When a user provides information containing multiple fields, extract ALL of them."
    },
    {
      "id": "RULE-003",
      "description": "One main question at a time on WhatsApp, 2-3 on Telegram, full form on Dashboard."
    },
    {
      "id": "RULE-004",
      "description": "Prioritize highest filtering power missing field. Among all missing fields, the one that most reduces the search space should be asked first."
    },
    {
      "id": "RULE-005",
      "description": "Launch search as soon as MINIMUM_SEARCH_READY is reached. DO NOT continue asking questions."
    },
    {
      "id": "RULE-006",
      "description": "Collect secondary preferences AFTER first search launch. Never collect before first search."
    },
    {
      "id": "RULE-007",
      "description": "Ask confirmation only for real ambiguity. Never ask 'is this correct?' for information the user explicitly provided."
    },
    {
      "id": "RULE-008",
      "description": "Never ask what can be deduced. If a field can be derived from other known fields, do not ask the user."
    },
    {
      "id": "RULE-009",
      "description": "Urgent requests skip optional fields. If urgency >= 2, launch search on minimum criteria only."
    },
    {
      "id": "RULE-010",
      "description": "Correction overrides previous value. When a user corrects a field, accept the new value without referring to the old one."
    },
    {
      "id": "RULE-011",
      "description": "Maximum 3 attempts per field before offering to escalate to human."
    },
    {
      "id": "RULE-012",
      "description": "Never promise loan approval. LAWIM does matching only on apparent compatibility."
    }
  ],
  "priority_calculation_formula": "priority = base_priority - (impact_filtering * 10) + (sensitivity * 5) - (ambiguity * 3)",
  "priority_factors": {
    "known_information": {
      "type": "binary",
      "description": "Whether this field is already confirmed"
    },
    "impact_filtering": {
      "type": "float_0_1",
      "description": "How much this field filters results (higher = ask earlier)"
    },
    "impact_matching": {
      "type": "float_0_1",
      "description": "How much this field affects matching score"
    },
    "sensitivity": {
      "type": "int_0_3",
      "description": "Privacy sensitivity (0=public, 3=confidential, higher = ask later)"
    },
    "ambiguity": {
      "type": "float_0_1",
      "description": "Whether the field needs clarification (higher = defer)"
    },
    "urgency": {
      "type": "int_0_3",
      "description": "User's expressed urgency level (higher = skip optional fields)"
    },
    "conversational_cost": {
      "type": "int_1_5",
      "description": "How complex the question is to ask (higher = more costly on WhatsApp)"
    }
  },
  "channel_adaptations": {
    "whatsapp": {
      "one_question_per_message": true,
      "max_question_length": 150,
      "avoid_lists": true,
      "defer_free_text": true,
      "use_quick_replies": true
    },
    "telegram": {
      "batch_2_3_fields": true,
      "use_formatting": true
    },
    "dashboard": {
      "full_form_one_page": true,
      "group_by_category": true,
      "inline_validation": true,
      "save_draft": true
    }
  }
}