{
  "roles": {
    "hard_constraint": {
      "description": "Field must match exactly for the result to be considered. Binary filter: pass or exclude.",
      "score_contribution": "filter",
      "evaluation_order": 1,
      "examples": [
        "city",
        "transaction_type",
        "property_type",
        "usage_prevu",
        "activite_prevue",
        "surface_min"
      ]
    },
    "soft_constraint": {
      "description": "Strong preference but flexible. Properties that don't match are NOT excluded but receive a score penalty.",
      "score_contribution": "weighted_scoring_0_to_100",
      "evaluation_order": 2,
      "examples": [
        "neighborhood",
        "budget",
        "chambres",
        "douches",
        "cuisine",
        "meuble",
        "parking",
        "securite",
        "eau",
        "electricite"
      ]
    },
    "ranking_preference": {
      "description": "Used ONLY to rank results, never to filter. Properties with this feature matching rank higher.",
      "score_contribution": "bonus_+5_to_+15",
      "evaluation_order": 3,
      "examples": [
        "etage",
        "balcon",
        "jardin",
        "piscine",
        "flux_passage",
        "visibilite_route",
        "duree_sejour",
        "urgence"
      ]
    },
    "exclusion": {
      "description": "Properties matching this criterion are explicitly excluded from results.",
      "score_contribution": "binary_exclude",
      "evaluation_order": 0,
      "examples": [
        "previously_rejected_properties",
        "user_declined_properties",
        "neighborhoods_explicitly_ruled_out"
      ]
    },
    "boost": {
      "description": "When matched, applies a fixed score boost above the base matching score.",
      "score_contribution": "fixed_additive_+10_to_+25_capped_at_+50",
      "evaluation_order": 4,
      "examples": [
        "exact_neighborhood_match_+25",
        "exact_city_match_+20",
        "budget_within_range_+15",
        "title_foncier_+10",
        "diaspora_investor_+20"
      ]
    },
    "penalty": {
      "description": "When missing or mismatched, applies a fixed score penalty.",
      "score_contribution": "fixed_subtractive_-5_to_-50_floored_at_0",
      "evaluation_order": 5,
      "examples": [
        "missing_budget_-10",
        "unclear_location_-10",
        "spam_like_-50",
        "missing_neighborhood_-5",
        "missed_visit_-25",
        "incomplete_documents_-30"
      ]
    },
    "informational_only": {
      "description": "Collected for display, context, or CRM purposes. Does NOT affect match score.",
      "score_contribution": "none",
      "evaluation_order": 6,
      "examples": [
        "nom",
        "email",
        "langue",
        "zone",
        "standing",
        "derived_profil",
        "commentaire"
      ]
    },
    "verification_only": {
      "description": "Used ONLY for verification purposes at transaction time. Does NOT affect matching.",
      "score_contribution": "none_blocks_transaction_if_fail",
      "evaluation_order": 7,
      "examples": [
        "telephone",
        "num_titre",
        "bornage",
        "certificat_urbanisme",
        "carte_professionnelle"
      ]
    },
    "transaction_blocker": {
      "description": "Must be resolved before a transaction can proceed. These are transaction-readiness gates.",
      "score_contribution": "none_blocks_transaction_until_resolved",
      "evaluation_order": 8,
      "examples": [
        "caution",
        "financing",
        "litiges_connus",
        "hypotheque",
        "documents_fiscaux"
      ]
    }
  },
