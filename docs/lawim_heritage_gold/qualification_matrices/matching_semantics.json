  "exclusion_rules": [
    {
      "condition": "status_archived",
      "action": "exclude",
      "description": "Property has been archived by owner"
    },
    {
      "condition": "status_sold",
      "action": "exclude",
      "description": "Property has been sold or rented"
    },
    {
      "condition": "status_withdrawn",
      "action": "exclude",
      "description": "Property listing has been withdrawn"
    },
    {
      "condition": "budget_outside_tolerance",
      "action": "exclude",
      "description": "Property price exceeds budget tolerance for hard_constraint"
    },
    {
      "condition": "city_mismatch",
      "action": "exclude",
      "description": "Property is in a different city (hard_constraint)"
    },
    {
      "condition": "transaction_type_mismatch",
      "action": "exclude",
      "description": "Transaction type incompatible (rent vs buy)"
    },
    {
      "condition": "property_type_mismatch",
      "action": "exclude",
      "description": "Property type incompatible"
    },
    {
      "condition": "user_rejected_property",
      "action": "exclude",
      "description": "User explicitly rejected this property previously"
    },
    {
      "condition": "litiges_non_resolus",
      "action": "exclude_from_transaction",
      "description": "Known legal disputes unresolved"
    },
    {
      "condition": "hypotheque_non_clearee",
      "action": "exclude_from_transaction",
      "description": "Mortgage or charge not cleared"
    },
    {
      "condition": "documents_manquants",
      "action": "exclude_from_transaction",
      "description": "Mandatory documents missing"
    },
    {
      "condition": "user_inactive_30_days",
      "action": "deprioritize",
      "description": "User has been inactive for 30+ days"
    }
  ],
  "scoring_formula": {
    "base": "total_score = match_score + boost_total - penalty_total",
    "match_score": "Sigma(field_weight_i * field_match_i) for all matching fields",
    "boost_total": "Sigma(boost_values) capped at +50",
    "penalty_total": "Sigma(penalty_values) floored at 0",
    "normalized": "max(0, min(100, score))"
  },
  "weight_distribution": {
    "RENT": {
      "geographical": 0.35,
      "budget": 0.3,
      "property": 0.25,
      "amenities": 0.1,
      "legal": 0.0
    },
    "BUY": {
      "geographical": 0.3,
      "budget": 0.25,
      "property": 0.25,
      "amenities": 0.1,
      "legal": 0.1
    },
    "INVEST": {
      "geographical": 0.25,
      "budget": 0.3,
      "property": 0.2,
      "amenities": 0.1,
      "legal": 0.15
    },
    "LAND_BUY": {
      "geographical": 0.3,
      "budget": 0.25,
      "property": 0.15,
      "amenities": 0.05,
      "legal": 0.25
    },
    "FINANCE": {
      "geographical": 0.2,
      "budget": 0.35,
      "property": 0.2,
      "amenities": 0.0,
      "legal": 0.25
    }
  },
  "thresholds": {
    "show_in_results": 40,
    "show_in_top_10": 50,
    "recommend_for_visit": 70,
    "recommend_for_transaction": 85
  },
  "boost_cap": 50,
  "evaluation_order": [
    "hard_constraint",
    "soft_constraint",
    "ranking_preference",
    "boost",
    "penalty",
    "informational_only",
    "verification_only",
    "transaction_blocker"
  ]
}