{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["DOM", "DOM.Iterable", "ES2020"],
    "allowJs": false,
    "allowImportingTsExtensions": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "ignoreDeprecations": "5.0",
    "baseUrl": ".",
    "paths": {
      "@ui": ["packages/ui/src/index.ts"],
      "@ui/*": ["packages/ui/src/*"],
      "@design-system": ["packages/design-system/src/index.ts"],
      "@design-system/*": ["packages/design-system/src/*"],
      "@api-sdk": ["packages/api-sdk/src/index.ts"],
      "@api-sdk/*": ["packages/api-sdk/src/*"],
      "@auth": ["packages/auth/src/index.ts"],
      "@auth/*": ["packages/auth/src/*"],
      "@maps": ["packages/maps/src/index.ts"],
      "@maps/*": ["packages/maps/src/*"],
      "@charts": ["packages/charts/src/index.ts"],
      "@charts/*": ["packages/charts/src/*"],
      "@forms": ["packages/forms/src/index.ts"],
      "@forms/*": ["packages/forms/src/*"],
      "@brain": ["packages/brain/src/index.ts"],
      "@brain/*": ["packages/brain/src/*"],
      "@conversation": ["packages/conversation/src/index.ts"],
      "@conversation/*": ["packages/conversation/src/*"],
      "@memory": ["packages/memory/src/index.ts"],
      "@memory/*": ["packages/memory/src/*"],
      "@digital-twin": ["packages/digital-twin/src/index.ts"],
      "@digital-twin/*": ["packages/digital-twin/src/*"],
      "@learning": ["packages/learning/src/index.ts"],
      "@learning/*": ["packages/learning/src/*"],
      "@agents": ["packages/agents/src/index.ts"],
      "@agents/*": ["packages/agents/src/*"],
      "@knowledge": ["packages/knowledge/src/index.ts"],
      "@knowledge/*": ["packages/knowledge/src/*"],
      "@workflows": ["packages/workflows/src/index.ts"],
      "@workflows/*": ["packages/workflows/src/*"]
    }
  },
  "include": ["apps/**/*", "packages/**/*", "tests/**/*", "vite-env.d.ts"],
  "references": []
}
