// LAWIM_V2 runtime schema v19 — aligned with code/lawim_v2/persistence.py manifest
// Fingerprint anchor: build_schema_fingerprint(build_application_schema_manifest())

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("LAWIM_DATABASE_URL")
}

model Organization {
  id            Int      @id @default(autoincrement())
  name          String
  slug          String   @unique
  kind          String   @default("agency")
  city          String?
  createdAt     String   @map("created_at")
  users         User[]
  properties    Property[] @relation("OwnerOrganization")
  conversations Conversation[]
  projects      Project[]

  @@index([createdAt, id], map: "idx_organizations_created_at")
  @@map("organizations")
}

model User {
  id             Int      @id @default(autoincrement())
  email          String   @unique
  username       String?  @unique
  fullName       String   @map("full_name")
  phoneE164      String?  @unique @map("phone_e164")
  preferredLanguage String @default("fr") @map("preferred_language")
  role           String
  organizationId Int?     @map("organization_id")
  passwordSalt   String   @map("password_salt")
  passwordHash   String   @map("password_hash")
  createdAt      String   @map("created_at")
  organization   Organization? @relation(fields: [organizationId], references: [id])
  sessions       Session[]
  conversations  Conversation[]
  messages       Message[] @relation("Sender")
  notifications  Notification[]
  projects       Project[]

  @@index([createdAt, id], map: "idx_users_created_at")
  @@index([organizationId, id], map: "idx_users_organization")
  @@map("users")
}

model Session {
  token     String @id
  userId    Int    @map("user_id")
  createdAt String @map("created_at")
  expiresAt String @map("expires_at")
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt], map: "idx_sessions_user_expires")
  @@index([expiresAt], map: "idx_sessions_expires_at")
  @@map("sessions")
}

model Property {
  id                  Int      @id @default(autoincrement())
  listingCode         String?  @unique @map("listing_code")
  title               String
  summary             String
  addressLine         String?  @map("address_line")
  city                String
  region              String?
  postalCode          String?  @map("postal_code")
  country             String
  searchKey           String?  @map("search_key")
  latitude            Float?
  longitude           Float?
  priceMin            Int?     @map("price_min")
  priceMax            Int?     @map("price_max")
  currency            String
  status              String
  availability        String   @default("available")
  propertyType        String   @map("property_type")
  ownerOrganizationId Int?     @map("owner_organization_id")
  bedrooms            Int      @default(0)
  bathrooms           Int      @default(0)
  areaSqm             Float    @default(0) @map("area_sqm")
  metadataJson        String   @default("{}") @map("metadata_json")
  version             Int      @default(1)
  publishedAt         String?  @map("published_at")
  deletedAt           String?  @map("deleted_at")
  createdAt           String   @map("created_at")
  ownerOrganization   Organization? @relation("OwnerOrganization", fields: [ownerOrganizationId], references: [id])
  media               Media[]
  conversations       Conversation[]

  @@index([status, city], map: "idx_properties_status_city")
  @@index([searchKey], map: "idx_properties_search_key")
  @@index([deletedAt], map: "idx_properties_deleted_at")
  @@index([createdAt, id], map: "idx_properties_created_at")
  @@index([ownerOrganizationId, status, deletedAt], map: "idx_properties_owner_status")
  @@map("properties")
}

model Media {
  id           Int      @id @default(autoincrement())
  propertyId   Int      @map("property_id")
  kind         String
  url          String
  caption      String
  storagePath  String?  @map("storage_path")
  mimeType     String?  @map("mime_type")
  sizeBytes    Int?     @map("size_bytes")
  thumbnailUrl String?  @map("thumbnail_url")
  metadataJson String   @default("{}") @map("metadata_json")
  position     Int      @default(0)
  version      Int      @default(1)
  deletedAt    String?  @map("deleted_at")
  createdAt    String   @map("created_at")
  property     Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId, position], map: "idx_media_property_position")
  @@index([createdAt, id], map: "idx_media_created_at")
  @@map("media")
}

model Conversation {
  id               Int      @id @default(autoincrement())
  propertyId       Int?     @map("property_id")
  userId           Int      @map("user_id")
  organizationId   Int?     @map("organization_id")
  subject          String
  status           String
  negotiationStage String   @default("inquiry") @map("negotiation_stage")
  createdAt        String   @map("created_at")
  updatedAt        String   @map("updated_at")
  property         Property? @relation(fields: [propertyId], references: [id])
  user             User     @relation(fields: [userId], references: [id])
  organization     Organization? @relation(fields: [organizationId], references: [id])
  messages         Message[]

  @@index([userId, updatedAt], map: "idx_conversations_user_updated")
  @@index([updatedAt, id], map: "idx_conversations_updated_at")
  @@index([organizationId, updatedAt, id], map: "idx_conversations_organization_updated")
  @@index([propertyId, updatedAt, id], map: "idx_conversations_property_updated")
  @@map("conversations")
}

model Message {
  id             Int          @id @default(autoincrement())
  conversationId Int          @map("conversation_id")
  senderUserId   Int          @map("sender_user_id")
  body           String
  createdAt      String       @map("created_at")
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation("Sender", fields: [senderUserId], references: [id])

  @@index([conversationId, createdAt], map: "idx_messages_conversation")
  @@map("messages")
}

model Event {
  id        Int    @id @default(autoincrement())
  kind      String
  payload   String
  createdAt String @map("created_at")

  @@index([createdAt, id], map: "idx_events_created_at")
  @@index([kind, createdAt, id], map: "idx_events_kind_created")
  @@map("events")
}

model Notification {
  id          Int     @id @default(autoincrement())
  userId      Int     @map("user_id")
  kind        String
  title       String
  body        String
  payloadJson String  @default("{}") @map("payload_json")
  readAt      String? @map("read_at")
  createdAt   String  @map("created_at")
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt, createdAt], map: "idx_notifications_user_read")
  @@map("notifications")
}

model SchemaMeta {
  key   String @id
  value String

  @@map("schema_meta")
}

model Project {
  id                Int      @id @default(autoincrement())
  userId            Int      @map("user_id")
  organizationId    Int?     @map("organization_id")
  title             String
  projectType       String   @map("project_type")
  objective         String
  budgetMin         Int?     @map("budget_min")
  budgetMax         Int?     @map("budget_max")
  currency          String   @default("XAF")
  locationCity      String?  @map("location_city")
  locationRegion    String?  @map("location_region")
  locationCountry   String?  @default("Cameroon") @map("location_country")
  locationLatitude  Float?   @map("location_latitude")
  locationLongitude Float?   @map("location_longitude")
  timelineHorizon   String?  @map("timeline_horizon")
  status            String   @default("draft")
  priority          String   @default("normal")
  progressPercent   Int      @default(0) @map("progress_percent")
  metadataJson      String   @default("{}") @map("metadata_json")
  archivedAt        String?  @map("archived_at")
  createdAt         String   @map("created_at")
  updatedAt         String   @map("updated_at")
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization      Organization? @relation(fields: [organizationId], references: [id])
  steps             ProjectStep[]
  checklistItems    ProjectChecklistItem[]
  stepHistory       ProjectStepHistory[]

  @@index([userId, status, createdAt], map: "idx_projects_user_status")
  @@index([organizationId, status, createdAt], map: "idx_projects_organization_status")
  @@index([createdAt, id], map: "idx_projects_created_at")
  @@map("projects")
}

model ProjectStep {
  id          Int      @id @default(autoincrement())
  projectId   Int      @map("project_id")
  stepKey     String   @map("step_key")
  title       String
  description String?
  position    Int      @default(0)
  status      String   @default("pending")
  milestone   String?
  nextAction  String?  @map("next_action")
  completedAt String?  @map("completed_at")
  createdAt   String   @map("created_at")
  updatedAt   String   @map("updated_at")
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  checklistItems ProjectChecklistItem[]
  history     ProjectStepHistory[]

  @@unique([projectId, stepKey], map: "project_steps_project_id_step_key_key")
  @@index([projectId, position], map: "idx_project_steps_project_position")
  @@map("project_steps")
}

model ProjectChecklistItem {
  id        Int      @id @default(autoincrement())
  projectId Int      @map("project_id")
  stepId    Int?     @map("step_id")
  label     String
  checked   Int      @default(0)
  position  Int      @default(0)
  createdAt String   @map("created_at")
  updatedAt String   @map("updated_at")
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  step      ProjectStep? @relation(fields: [stepId], references: [id], onDelete: Cascade)

  @@index([projectId, stepId, position], map: "idx_project_checklist_project")
  @@map("project_checklist_items")
}

model ProjectStepHistory {
  id         Int      @id @default(autoincrement())
  projectId  Int      @map("project_id")
  stepId     Int      @map("step_id")
  fromStatus String?  @map("from_status")
  toStatus   String   @map("to_status")
  note       String?
  createdAt  String   @map("created_at")
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  step       ProjectStep @relation(fields: [stepId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt, id], map: "idx_project_step_history_project")
  @@map("project_step_history")
}
