# Development environment

APP_ENV=development
STACK_PROFILE=development
LOG_LEVEL=debug
PUBLIC_BASE_URL=http://localhost:3000
SECRET_PROVIDER=external

# Runtime (non-secret defaults)
LAWIM_HOST=127.0.0.1
LAWIM_PORT=3000
LAWIM_DB_PATH=data/runtime/lawim.sqlite3
LAWIM_DB_DRIVER=sqlite
LAWIM_DB_FALLBACK=true
LAWIM_SEED_DEMO_DATA=true
LAWIM_SESSION_TTL_SECONDS=604800
LAWIM_MEDIA_STORAGE_PATH=data/runtime/media
LAWIM_MAX_UPLOAD_BYTES=5242880
LAWIM_MAX_JSON_BODY_BYTES=1048576
LAWIM_MATCH_MIN_SCORE=10
LAWIM_METRICS_ENABLED=true

# Optional PostgreSQL (not required)
# LAWIM_DB_DRIVER=postgresql
# LAWIM_DATABASE_URL=postgresql://lawim:lawim@localhost:5432/lawim_v2

# Green API WhatsApp
GREEN_API_API_URL=https://7107.api.greenapi.com
GREEN_API_MEDIA_URL=https://7107.api.greenapi.com
GREEN_API_ID_INSTANCE=7107644927
GREEN_API_WEBHOOK_URL=https://api.lawim.app/api/notifications/whatsapp/webhook
GREEN_API_PHONE=237650000000
TELEGRAM_BOT_USERNAME=lawim_bot
TELEGRAM_BOT_NAME=lawim
TELEGRAM_WEBHOOK_URL=https://api.lawim.app/api/notifications/telegram/webhook

# Secrets are injected outside the repository.
