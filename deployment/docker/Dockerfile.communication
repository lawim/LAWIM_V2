# Communication Service - Multi-channel messaging
FROM python:3.11-slim

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
  gcc postgresql-client redis-tools \
  && rm -rf /var/lib/apt/lists/*

COPY requirements.txt requirements-postgresql.txt ./
RUN pip install --no-cache-dir -r requirements.txt -r requirements-postgresql.txt

COPY code/lawim_v2 ./lawim_v2
COPY lawim_runtime ./lawim_runtime
COPY pyproject.toml ./

ENV PYTHONUNBUFFERED=1
ENV PORT=8004

HEALTHCHECK --interval=30s --timeout=10s --start-period=40s --retries=3 \
  CMD python -c "import requests; requests.get('http://localhost:8004/health')"

EXPOSE 8004

CMD ["uvicorn", "lawim_v2.communication:app", "--host", "0.0.0.0", "--port", "8004", "--workers", "4"]
