# LAWIM V2 Environment Configuration Template
# Copy to appropriate .env.{environment} file and configure

# =============================================================================
# GENERAL
# =============================================================================
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=debug

# =============================================================================
# FRONTEND
# =============================================================================
NODE_ENV=development
VITE_LAWIM_API_URL=http://localhost:8000
VITE_LAWIM_USE_MOCKS=false
VITE_LAWIM_TIMEOUT=30000

# =============================================================================
# BACKEND
# =============================================================================
PYTHONUNBUFFERED=1
PORT=8000
WORKERS=1

# =============================================================================
# DATABASE
# =============================================================================
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=lawim
DATABASE_PASSWORD=change_me_in_production
DATABASE_NAME=lawim
DATABASE_URL=postgresql://lawim:change_me_in_production@localhost:5432/lawim

# =============================================================================
# REDIS
# =============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=change_me_in_production
REDIS_DB=0
REDIS_URL=redis://:change_me_in_production@localhost:6379/0

# =============================================================================
# AUTHENTICATION
# =============================================================================
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
REFRESH_TOKEN_EXPIRATION_DAYS=30

# =============================================================================
# SECURITY
# =============================================================================
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
CORS_ALLOW_CREDENTIALS=true
CSRF_ENABLED=true
SECURE_COOKIES=false

# =============================================================================
# EMAIL/SMTP
# =============================================================================
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@lawim.app
SMTP_FROM_NAME=LAWIM

# =============================================================================
# EXTERNAL SERVICES
# =============================================================================

# WhatsApp Integration
WHATSAPP_API_KEY=your-whatsapp-api-key
WHATSAPP_BUSINESS_ACCOUNT_ID=your-account-id
WHATSAPP_PHONE_NUMBER_ID=your-phone-id

# Green API WhatsApp
GREEN_API_API_URL=https://7107.api.greenapi.com
GREEN_API_MEDIA_URL=https://7107.api.greenapi.com
GREEN_API_ID_INSTANCE=7107644927
GREEN_API_TOKEN_INSTANCE=your-green-api-token-instance
GREEN_API_WEBHOOK_SECRET=your-green-api-webhook-secret
GREEN_API_WEBHOOK_URL=https://api.lawim.app/api/notifications/whatsapp/webhook
GREEN_API_PHONE=237686822667
LAWIM_WHATSAPP_NUMBER=237686822667
WHATSAPP_PUBLIC_NUMBER=237686822667

# Telegram Bot
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_BOT_USERNAME=lawim_bot
TELEGRAM_BOT_NAME=lawim
TELEGRAM_WEBHOOK_URL=https://api.lawim.app/api/notifications/telegram/webhook
TELEGRAM_WEBHOOK_SECRET=your-telegram-webhook-secret

# AI Orchestrator
AI_ORCHESTRATOR_ENABLED=true
AI_PROVIDER_DEEPSEEK_ENABLED=true
AI_PROVIDER_OPENAI_ENABLED=true
AI_PROVIDER_GEMINI_PRIMARY_ENABLED=true
AI_PROVIDER_GEMINI_SECONDARY_ENABLED=true
AI_PRIMARY_PROVIDER=deepseek
AI_COMPLEX_PROVIDER=openai
AI_FALLBACK_CHAIN=deepseek,openai,gemini_primary,gemini_secondary
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_BASE_URL=https://api.deepseek.com
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
GEMINI_PRIMARY_API_KEY=
GEMINI_PRIMARY_MODEL=gemini-3.5-flash
GEMINI_SECONDARY_API_KEY=
GEMINI_SECONDARY_MODEL=gemini-2.5-flash
AI_REQUEST_TIMEOUT_SECONDS=30
AI_TOTAL_TIMEOUT_SECONDS=75
AI_MAX_RETRIES_PER_PROVIDER=1
AI_CIRCUIT_BREAKER_ENABLED=true
AI_CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
AI_CIRCUIT_BREAKER_WINDOW_SECONDS=300
AI_CIRCUIT_BREAKER_OPEN_SECONDS=600
AI_CIRCUIT_BREAKER_HALF_OPEN_REQUESTS=1
AI_CREDIT_WARNING_PERCENT=20
AI_CREDIT_CRITICAL_PERCENT=10
AI_CREDIT_EXHAUSTED_PERCENT=2
AI_PROVIDER_INACTIVITY_MONITORING_ENABLED=true
AI_PROVIDER_INACTIVITY_WARNING_HOURS=24
AI_PROVIDER_INACTIVITY_CRITICAL_HOURS=72
AI_PROVIDER_HEALTHCHECK_INTERVAL_MINUTES=30
AI_DAILY_BUDGET_LIMIT=
AI_MONTHLY_BUDGET_LIMIT=
AI_MAX_COST_PER_REQUEST=
AI_MAX_COST_PER_CONVERSATION=
AI_ALERTS_ENABLED=true
AI_ALERT_EMAIL_ENABLED=false
AI_ALERT_WHATSAPP_ENABLED=false
AI_ALERT_TELEGRAM_ENABLED=false
AI_ALERT_ADMIN_RECIPIENTS=
COMMUNICATION_FALLBACK_ENABLED=true
WHATSAPP_FALLBACK_ENABLED=true
TELEGRAM_FALLBACK_ENABLED=true
FALLBACK_WHEN_AI_UNCONFIGURED=true
FALLBACK_WHEN_AI_ERROR=true
FALLBACK_WHEN_NO_ANSWER=true
FALLBACK_ESCALATE_TO_HUMAN=true
FALLBACK_DEFAULT_LANGUAGE=fr
AI_LEARNING_ENABLED=true
AI_LEARNING_AUTO_PUBLISH=false
AI_LEARNING_REQUIRES_HUMAN_APPROVAL=true
AI_LEARNING_ANONYMIZATION_ENABLED=true
HUMAN_ESCALATION_ENABLED=true
HUMAN_ESCALATION_AFTER_FALLBACK_COUNT=2
HUMAN_ESCALATION_ON_USER_REQUEST=true
HUMAN_ESCALATION_ON_ALL_PROVIDERS_FAILED=true

# Google Services
GOOGLE_API_KEY=your-google-api-key
GOOGLE_MAPS_API_KEY=your-maps-api-key

# Campay Payment Gateway
CAMPAY_API_KEY=your-campay-api-key
CAMPAY_API_SECRET=your-campay-api-secret
CAMPAY_WEBHOOK_SECRET=your-webhook-secret

# =============================================================================
# BACKUP & STORAGE
# =============================================================================

# Local Backup
BACKUP_LOCAL_PATH=/data/backups
BACKUP_RETENTION_DAYS=30

# Remote Backup (Google Drive / rclone)
RCLONE_REMOTE=gdrive
RCLONE_CONFIG_PATH=/etc/rclone/rclone.conf
BACKUP_REMOTE_ENABLED=false

# Google Drive API
GOOGLE_DRIVE_BACKUP_FOLDER_ID=your-folder-id

# =============================================================================
# MONITORING & LOGGING
# =============================================================================
SENTRY_DSN=your-sentry-dsn
LOG_FORMAT=json
LOG_HANDLERS=console,file
LOG_FILE_PATH=/var/log/lawim/app.log
LOG_FILE_MAX_BYTES=10485760
LOG_FILE_BACKUP_COUNT=5

# =============================================================================
# CELERY
# =============================================================================
CELERY_BROKER_URL=redis://:change_me_in_production@localhost:6379/0
CELERY_RESULT_BACKEND=redis://:change_me_in_production@localhost:6379/1
CELERY_WORKER_CONCURRENCY=4
CELERY_WORKER_PREFETCH_MULTIPLIER=4

# =============================================================================
# OBSERVABILITY
# =============================================================================
ENABLE_PROFILING=false
ENABLE_TRACING=false
ENABLE_METRICS=true

# =============================================================================
# FEATURE FLAGS
# =============================================================================
FEATURE_AI_ASSISTANT=true
FEATURE_MARKETPLACE=true
FEATURE_ESTIMATION=true
FEATURE_WORKFLOW_AUTOMATION=true
FEATURE_ADVANCED_ANALYTICS=false

# =============================================================================
# RATE LIMITING
# =============================================================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60
RATE_LIMIT_AUTH_REQUESTS=5
RATE_LIMIT_AUTH_PERIOD=300

# =============================================================================
# FILE UPLOADS
# =============================================================================
MAX_UPLOAD_SIZE_MB=20
ALLOWED_UPLOAD_EXTENSIONS=pdf,doc,docx,jpg,jpeg,png,gif
UPLOAD_PATH=/data/uploads

# =============================================================================
# CACHE
# =============================================================================
CACHE_TTL_SECONDS=3600
CACHE_REDIS_ENABLED=true
CACHE_MEMORY_ENABLED=false

# =============================================================================
# API VERSIONING
# =============================================================================
API_VERSION=2.0
API_BASE_PATH=/api
