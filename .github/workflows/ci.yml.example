# Example only. Do not rename this file to `.yml` until the workflow is approved.
name: lawim-ci-example

on:
  push:
    branches:
      - main
      - sprint/**
      - ticket/**
      - release/**
      - hotfix/**
  pull_request:
    branches:
      - main
      - sprint/**
      - release/**
      - hotfix/**
  workflow_dispatch: {}

permissions:
  contents: read
  pull-requests: read
  actions: read
  checks: read

concurrency:
  group: lawim-ci-${{ github.ref }}
  cancel-in-progress: true

env:
  APP_ENV: ci
  STACK_PROFILE: ci
  LOG_LEVEL: info
  SECRET_PROVIDER: external

jobs:
  preflight:
    name: Preflight and contract checks
    runs-on: ubuntu-latest
    steps:
      - name: Checkout repository
        uses: actions/checkout@v4
      - name: Validate repository contract
        run: echo "Conceptual branch and file contract checks only"
      - name: Validate Compose overlays
        run: echo "docker compose -f docker/compose/docker-compose.base.yml -f docker/compose/docker-compose.development.yml config"
      - name: Validate secret templates
        run: echo "Template check only; no real secrets"

  build_test_analyze:
    name: Build, test and analyse
    runs-on: ubuntu-latest
    needs: preflight
    steps:
      - name: Checkout repository
        uses: actions/checkout@v4
      - name: Build the shared Docker foundation and overlays
        run: echo "Conceptual build for the shared base plus development, staging and production overlays"
      - name: Run tests and static analysis
        run: echo "Conceptual test and analysis gates"
      - name: Validate migration contract
        run: echo "Future schema or Prisma migration gate placeholder"
      - name: Produce packaging evidence
        run: echo "Package evidence only; no image publication in T01.08"
